{
    "name": "sc-ast-view",
    "displayName": "SC/SG AST View",
    "description": "实时显示 sc / sg 源码的 AST 结构树，并可切换查看基于树结构再生成的源码",
    "version": "0.1.0",
    "publisher": "sc-lang",
    "engines": { "vscode": "^1.75.0" },
    "categories": ["Programming Languages", "Visualization"],
    "main": "./extension.js",
    "activationEvents": ["onLanguage:sc", "onLanguage:sg"],
    "contributes": {
        "views": {
            "explorer": [
                {
                    "id": "scAstView",
                    "name": "SC AST",
                    "icon": "$(list-tree)",
                    "contextualTitle": "SC AST"
                }
            ]
        },
        "commands": [
            {
                "command": "scAst.refresh",
                "title": "SC AST: 刷新",
                "icon": "$(refresh)"
            },
            {
                "command": "scAst.toggleTreeSource",
                "title": "SC AST: 切换树结构源码视图",
                "icon": "$(code)"
            },
            {
                "command": "scAst.toggleApi",
                "title": "SC AST: 切换导出接口摘要视图",
                "icon": "$(symbol-interface)"
            },
            {
                "command": "scAst.showGraph",
                "title": "SC: 打开程序结构依赖图",
                "icon": "$(type-hierarchy)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "scAst.showGraph",
                    "when": "resourceLangId == sc",
                    "group": "navigation@1"
                }
            ],
            "view/title": [
                {
                    "command": "scAst.toggleApi",
                    "when": "view == scAstView",
                    "group": "navigation@1"
                },
                {
                    "command": "scAst.toggleTreeSource",
                    "when": "view == scAstView",
                    "group": "navigation@2"
                },
                {
                    "command": "scAst.refresh",
                    "when": "view == scAstView",
                    "group": "navigation@3"
                }
            ]
        },
        "configuration": {
            "title": "SC AST",
            "properties": {
                "scAst.sccPath": {
                    "type": "string",
                    "default": "",
                    "description": "scc 编译器路径；留空时依次查找工作区 compiler/build/scc 与 PATH 中的 scc"
                },
                "scAst.clangLibPath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "解析 inc 引入的 C 头文件描述符的方式：\n\n- 留空：退化为头文件文本匹配（仅能识别已用符号）\n- `auto`：自动检测本地平台默认位置的 libclang（Xcode/CommandLineTools/Homebrew/LLVM）\n- 路径：指定 libclang 动态库（如 `/Library/Developer/CommandLineTools/usr/lib/libclang.dylib` 或 `.so`/`.dll`）\n\n启用 libclang 后可枚举 C 头全部描述符并统计使用/未用；目标平台头解析复用交叉编译配置（triple/sysroot/inc/cflags）。"
                }
            }
        }
    }
}
