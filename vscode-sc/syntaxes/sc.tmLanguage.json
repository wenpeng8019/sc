{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "sc",
    "scopeName": "source.sc",
    "patterns": [
        { "include": "#comment" },
        { "include": "#inc-decl" },
        { "include": "#add-decl" },
        { "include": "#root-marker" },
        { "include": "#export-prefix" },
        { "include": "#def-decl" },
        { "include": "#cls-decl" },
        { "include": "#fnc-decl" },
        { "include": "#for-in" },
        { "include": "#var-decl" },
        { "include": "#label-decl" },
        { "include": "#ret-call-sugar" },
        { "include": "#qualified-type" },
        { "include": "#keywords" },
        { "include": "#builtins" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#macro-op" },
        { "include": "#numbers" },
        { "include": "#function-call" },
        { "include": "#meta-suffix" },
        { "include": "#operators" }
    ],
    "repository": {
        "comment": {
            "name": "comment.line.number-sign.sc",
            "match": "#.*$"
        },
        "inc-decl": {
            "match": "^\\s*(inc)\\s+(\\S+)",
            "captures": {
                "1": { "name": "keyword.control.import.sc" },
                "2": { "name": "string.unquoted.include.sc" }
            }
        },
        "add-decl": {
            "match": "^\\s*(add)\\s+(\\S+)",
            "captures": {
                "1": { "name": "keyword.control.import.sc" },
                "2": { "name": "string.unquoted.include.sc" }
            }
        },
        "export-prefix": {
            "name": "storage.modifier.export.sc",
            "match": "^\\s*(@)(?=inc|def|fnc|var|let)"
        },
        "root-marker": {
            "name": "storage.modifier.root.sc",
            "match": "^\\s*(@@)(?=\\s|#|$)"
        },
        "def-decl": {
            "begin": "\\b(def)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "beginCaptures": {
                "1": { "name": "keyword.declaration.def.sc" },
                "2": { "name": "entity.name.type.sc" }
            },
            "end": "(?=[{(\\[<~=]|->|$)",
            "patterns": [
                { "include": "#comment" },
                {
                    "name": "keyword.operator.variadic.sc",
                    "match": "\\.\\.\\."
                },
                {
                    "name": "variable.parameter.sc",
                    "match": "[A-Za-z_][A-Za-z0-9_]*"
                },
                {
                    "name": "punctuation.separator.parameter.sc",
                    "match": "[:,]"
                }
            ]
        },
        "cls-decl": {
            "begin": "\\b(cls)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "beginCaptures": {
                "1": { "name": "keyword.declaration.def.sc" },
                "2": { "name": "entity.name.type.sc" }
            },
            "end": "(?=[{(\\[<~=:]|->|$)",
            "patterns": [
                { "include": "#comment" }
            ]
        },
        "fnc-decl": {
            "match": "\\b(fnc)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.function.sc" },
                "2": { "name": "entity.name.function.sc" }
            }
        },
        "for-in": {
            "begin": "^\\s*(for)\\b(?=[^;\\n]*\\bin\\b)",
            "beginCaptures": {
                "1": { "name": "keyword.control.sc" }
            },
            "end": "$",
            "patterns": [
                { "include": "#comment" },
                {
                    "name": "keyword.control.sc",
                    "match": "\\b(in|revert|step|offset|num)\\b"
                },
                { "include": "#qualified-type" },
                { "include": "#builtins" },
                { "include": "#constants" },
                { "include": "#types" },
                { "include": "#strings" },
                { "include": "#chars" },
                { "include": "#numbers" },
                { "include": "#function-call" },
                { "include": "#meta-suffix" },
                { "include": "#operators" }
            ]
        },
        "var-decl": {
            "match": "\\b(var|let|tls|mod)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.var.sc" },
                "2": { "name": "variable.other.declaration.sc" }
            }
        },
        "label-decl": {
            "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:(?=\\s*(#.*)?$)",
            "captures": {
                "1": { "name": "entity.name.label.sc" }
            }
        },
        "qualified-type": {
            "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*((?:const|volatile)(?:\\s+(?:const|volatile))*)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "storage.modifier.qualifier.sc" },
                "2": { "name": "entity.name.type.annotated.sc" }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.sc",
                    "match": "\\b(if|else|while|do|for|case|through|as|goto|return|break|continue|run|sync|done|await|async|final)\\b"
                },
                {
                    "name": "keyword.control.io.sc",
                    "match": "\\b(print|stringify|assert)\\b"
                },
                {
                    "name": "keyword.control.expand.sc",
                    "match": "^\\s*(mix)\\b"
                },
                {
                    "name": "keyword.declaration.sc",
                    "match": "\\b(def|fnc|rpc|var|let|tls|mod|inc|add|tst|cls)\\b"
                },
                {
                    "name": "keyword.declaration.sc",
                    "match": "^\\s*(dim)\\b"
                },
                {
                    "name": "storage.modifier.qualifier.sc",
                    "match": "\\b(const|volatile|restrict)\\b"
                },
                {
                    "name": "variable.language.this.sc",
                    "match": "\\b(this|self)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.sc",
                    "match": "\\b(sizeof|offsetof|base|instanceOf)\\b"
                },
                {
                    "name": "variable.language.linked.sc",
                    "match": "(?<=->|\\.)(prev|next)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.sc",
                    "match": "\\b(true|false|nil|ok|positive|negative|unknown)\\b"
                },
                {
                    "name": "variable.language.ret-result.sc",
                    "match": "\\$"
                }
            ]
        },
        "ret-call-sugar": {
            "match": "^\\s*(!!|>=|<=|!|>|<)\\s+(?=[A-Za-z_])",
            "captures": {
                "1": { "name": "keyword.operator.ret-sugar.sc" }
            }
        },
        "types": {
            "patterns": [
                {
                    "match": "(?:(?<=[A-Za-z0-9_&)\\]]:)|(?<=::))\\s*((?:const|volatile|restrict)(?:\\s+(?:const|volatile|restrict))*)\\s+(@)(?=\\s*(?:,|#|$|\\)|\\]|\\}))",
                    "captures": {
                        "1": { "name": "storage.modifier.qualifier.sc" },
                        "2": { "name": "storage.type.primitive.sc" }
                    }
                },
                {
                    "name": "storage.type.primitive.sc",
                    "match": "(?:(?<=[A-Za-z0-9_&)\\]]:)|(?<=::))\\s*@(?=\\s*(?:,|#|$|\\)|\\]|\\}))"
                },
                {
                    "match": "(?:(?<=[A-Za-z0-9_&)\\]]:)|(?<=::))\\s*((?:const|volatile|restrict)(?:\\s+(?:const|volatile|restrict))*)\\s+(&&?)(?=\\s*(?:,|#|$|\\)|\\]|\\}))",
                    "captures": {
                        "1": { "name": "storage.modifier.qualifier.sc" },
                        "2": { "name": "storage.type.primitive.sc" }
                    }
                },
                {
                    "name": "storage.type.primitive.sc",
                    "match": "(?:(?<=[A-Za-z0-9_&)\\]]:)|(?<=::))\\s*&&?(?=\\s*(?:,|#|$|\\)|\\]|\\}))"
                },
                {
                    "name": "storage.type.primitive.sc",
                    "match": "\\b(i1|i2|i4|i8|u1|u2|u4|u8|bool|char|f4|f8|ret|tril|object)\\b"
                },
                {
                    "name": "entity.name.type.library.sc",
                    "match": "\\b(va_list|adt_obj|string|list|dict|ring|bst|heap|trie|lru|dim|json|thread|mutex|cond|pool|com|chain|future|operand)\\b"
                },
                {
                    "name": "storage.type.primitive.sc",
                    "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*\\b(i1|i2|i4|i8|u1|u2|u4|u8|bool|char|f4|f8|ret|tril|object)\\b(?!\\s*[:(])"
                },
                {
                    "name": "entity.name.type.library.sc",
                    "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*\\b(va_list|adt_obj|string|list|dict|ring|bst|heap|trie|lru|dim|json|thread|mutex|cond|pool|com|chain|future|operand)\\b(?!\\s*[:(])"
                },
                {
                    "name": "entity.name.type.annotated.sc",
                    "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s*[:(])"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.sc",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                { "name": "constant.character.escape.sc", "match": "\\\\." }
            ]
        },
        "chars": {
            "name": "string.quoted.single.sc",
            "begin": "'",
            "end": "'",
            "patterns": [
                { "name": "constant.character.escape.sc", "match": "\\\\." }
            ]
        },
        "macro-op": {
            "patterns": [
                {
                    "name": "string.interpolated.stringify.sc",
                    "match": "`[A-Za-z_][A-Za-z0-9_]*`"
                },
                {
                    "name": "keyword.operator.paste.sc",
                    "match": "(?<=[A-Za-z0-9_])\\\\(?=[A-Za-z0-9_`])"
                }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.sc", "match": "\\b0[xX][0-9a-fA-F]+[uUlLbBwW]*\\b" },
                { "name": "constant.numeric.float.sc", "match": "\\b[0-9]+\\.[0-9]+[fFlL]?\\b" },
                { "name": "constant.numeric.integer.sc", "match": "\\b[0-9]+[uUlLbBwW]*\\b" }
            ]
        },
        "function-call": {
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
            "captures": { "1": { "name": "entity.name.function.call.sc" } }
        },
        "meta-suffix": {
            "patterns": [
                {
                    "name": "storage.modifier.pointer.sc",
                    "match": "(?<=[A-Za-z0-9_\\]])&"
                },
                {
                    "name": "storage.modifier.autopointer.sc",
                    "match": "(?<=[A-Za-z0-9_\\]])@"
                },
                {
                    "name": "storage.modifier.array.sc",
                    "match": "(?<=[A-Za-z0-9_])\\[[0-9A-Za-z_]*\\]"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "punctuation.separator.item.sc",
                    "match": "^\\s*-\\s*$"
                },
                {
                    "name": "keyword.operator.arrow.sc",
                    "match": "->"
                },
                {
                    "name": "punctuation.definition.ellipsis.sc",
                    "match": "\\.\\.\\."
                },
                {
                    "name": "keyword.operator.sc",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.sc",
                    "match": "(<<=|>>=|==|!=|<=|>=|&&|\\|\\||\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<|>>|\\+\\+|--|[+\\-*/%<>=!&|^~?])"
                }
            ]
        }
    }
}
