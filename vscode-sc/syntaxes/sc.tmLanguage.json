{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "sc",
    "scopeName": "source.sc",
    "patterns": [
        { "include": "#comment" },
        { "include": "#inc-decl" },
        { "include": "#export-prefix" },
        { "include": "#def-decl" },
        { "include": "#fnc-decl" },
        { "include": "#var-decl" },
        { "include": "#label-decl" },
        { "include": "#keywords" },
        { "include": "#builtins" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#numbers" },
        { "include": "#function-call" },
        { "include": "#meta-suffix" },
        { "include": "#operators" }
    ],
    "repository": {
        "comment": {
            "name": "comment.line.number-sign.sc",
            "match": "#.*$"
        },
        "inc-decl": {
            "match": "^\\s*(inc)\\s+(\\S+)",
            "captures": {
                "1": { "name": "keyword.control.import.sc" },
                "2": { "name": "string.unquoted.include.sc" }
            }
        },
        "export-prefix": {
            "name": "storage.modifier.export.sc",
            "match": "^\\s*(@)(?=inc|def|fnc|var|let)"
        },
        "def-decl": {
            "match": "\\b(def)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.def.sc" },
                "2": { "name": "entity.name.type.sc" }
            }
        },
        "fnc-decl": {
            "match": "\\b(fnc)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.function.sc" },
                "2": { "name": "entity.name.function.sc" }
            }
        },
        "var-decl": {
            "match": "\\b(var|let|tls)\\s+([A-Za-z_][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.var.sc" },
                "2": { "name": "variable.other.declaration.sc" }
            }
        },
        "label-decl": {
            "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:(?=\\s*(#.*)?$)",
            "captures": {
                "1": { "name": "entity.name.label.sc" }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.sc",
                    "match": "\\b(if|else|while|do|for|case|through|goto|return|break|continue|run|wait)\\b"
                },
                {
                    "name": "keyword.control.io.sc",
                    "match": "\\b(print)\\b|\\bstring\\b(?=\\s*\\((?!\\s*\\)))"
                },
                {
                    "name": "keyword.declaration.sc",
                    "match": "\\b(def|fnc|rpc|var|let|tls|inc)\\b"
                },
                {
                    "name": "variable.language.this.sc",
                    "match": "\\bthis\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.sc",
                    "match": "\\b(sizeof|offsetof)\\b"
                },
                {
                    "name": "variable.language.linked.sc",
                    "match": "(?<=->|\\.)(prev|next)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.sc",
                    "match": "\\b(true|false|nil)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.sc",
                    "match": "\\b(i1|i2|i4|i8|u1|u2|u4|u8|bool|char|f4|f8)\\b"
                },
                {
                    "name": "entity.name.type.library.sc",
                    "match": "\\b(va_list|adt_obj|string|list|dict|dim|json|thread|mutex|cond|pool)\\b"
                },
                {
                    "name": "storage.type.primitive.sc",
                    "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*\\b(i1|i2|i4|i8|u1|u2|u4|u8|bool|char|f4|f8)\\b(?!\\s*[:(])"
                },
                {
                    "name": "entity.name.type.library.sc",
                    "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*\\b(va_list|adt_obj|string|list|dict|dim|json|thread|mutex|cond|pool)\\b(?!\\s*[:(])"
                },
                {
                    "name": "entity.name.type.annotated.sc",
                    "match": "(?<=[A-Za-z0-9_&)\\]]:)\\s*\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s*[:(])"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.sc",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                { "name": "constant.character.escape.sc", "match": "\\\\." }
            ]
        },
        "chars": {
            "name": "string.quoted.single.sc",
            "begin": "'",
            "end": "'",
            "patterns": [
                { "name": "constant.character.escape.sc", "match": "\\\\." }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.sc", "match": "\\b0[xX][0-9a-fA-F]+[uUlL]*\\b" },
                { "name": "constant.numeric.float.sc", "match": "\\b[0-9]+\\.[0-9]+[fFlL]?\\b" },
                { "name": "constant.numeric.integer.sc", "match": "\\b[0-9]+[uUlL]*\\b" }
            ]
        },
        "function-call": {
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
            "captures": { "1": { "name": "entity.name.function.call.sc" } }
        },
        "meta-suffix": {
            "patterns": [
                {
                    "name": "storage.modifier.pointer.sc",
                    "match": "(?<=[A-Za-z0-9_\\]])&"
                },
                {
                    "name": "storage.modifier.array.sc",
                    "match": "(?<=[A-Za-z0-9_])\\[[0-9A-Za-z_]*\\]"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "punctuation.separator.item.sc",
                    "match": "^\\s*-\\s*$"
                },
                {
                    "name": "keyword.operator.arrow.sc",
                    "match": "->"
                },
                {
                    "name": "punctuation.definition.ellipsis.sc",
                    "match": "\\.\\.\\."
                },
                {
                    "name": "keyword.operator.sc",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.sc",
                    "match": "(<<=|>>=|==|!=|<=|>=|&&|\\|\\||\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<|>>|\\+\\+|--|[+\\-*/%<>=!&|^~?])"
                }
            ]
        }
    }
}
