{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(def|fnc|if|else|while|for)\\b.*$",
        "decreaseIndentPattern": "^\\s*$"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(def|fnc|if|else|while|for)\\b.*$",
            "action": { "indent": "indent" }
        }
    ]
}
