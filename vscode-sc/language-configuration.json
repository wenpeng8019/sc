{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "(^\\s*(def|fnc|if|else|while|do|for|case)\\b.*$)|(^\\s*[A-Za-z_][A-Za-z0-9_]*:\\s*(#.*)?$)",
        "decreaseIndentPattern": "^\\s*$"
    },
    "onEnterRules": [
        {
            "beforeText": "(^\\s*(def|fnc|if|else|while|do|for|case)\\b.*$)|(^\\s*[A-Za-z_][A-Za-z0-9_]*:\\s*(#.*)?$)",
            "action": { "indent": "indent" }
        }
    ]
}
