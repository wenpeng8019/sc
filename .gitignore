# 构建产物
/build/
compiler/build/
compiler/build-uv/
compiler/build-dist/
compiler/build-ssl/
compiler/build-linux/
templates/utils/wsi/build/
*.o
*.out
*.exe
scc

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.crossnote
.venv/
.tmp/

# 本地备份目录
.backup/

# 示例编译产物（--build 产物：无后缀可执行文件与生成的 C/头文件）
examples/feature[0-9]
examples/*.c
examples/*.h
examples/*.dSYM/

# 第三方依赖构建产物（vendor 源码保留，仅忽略编译输出）
vendor/libuv/build/

# 后端选型参考源码（bgfx/sokol/glfw，仅本地比对参考，暂不入库；
# 若某个转正为 sc 后端依赖，再从此处移除对应条目）
vendor/glfw/
vendor/sokol/
vendor/bgfx/

# ssh 组件自包含静态库（host 构建产物，由 templates/utils/build_libssh2.sh 生成）
templates/utils/libssh2.a

# plib 跨平台库模板构建产物
templates/plib/*.a
templates/utils/win/*.o
templates/utils/win/*.a
