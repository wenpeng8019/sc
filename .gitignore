# 构建产物
# 任意层级中名为 build 的目录一律视为编译产物，不入库
build/
compiler/build-uv/
compiler/build-dist/
compiler/build-ssl/
compiler/build-linux/
*.o
*.out
*.exe
scc

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.crossnote
.venv/
.tmp/

# 本地备份目录
.backup/

# 示例编译产物（--build 产物：无后缀可执行文件与生成的 C/头文件）
examples/feature[0-9]
examples/*.c
examples/*.h
examples/*.dSYM/
templates/demo/gpu_shader/out/
templates/demo/gpu_demo
templates/demo/gpu_shader/*.frag
templates/demo/gpu_shader/*.vert
templates/demo/gpu_shader/*.metal
templates/demo/gpu_shader/*.reflect.json
templates/demo/spc_kernel/out/
templates/demo/spc_model/tiny.mlmodelc/
templates/demo/spc_model/tiny.mlpackage/
templates/demo/spc_model/tiny_ref.npy

# app 脚手架构建产物（build/ 目录由全局规则忽略；此处仅额外产物）
templates/app/hello-win/hello.exe

# hello-android@gradle：gradle 工程产物（嵌套 build/ 由全局规则忽略；本地 wrapper/局部配置）
templates/app/hello-android@gradle/.gradle/
templates/app/hello-android@gradle/local.properties
templates/app/hello-android@gradle/gradlew
templates/app/hello-android@gradle/gradlew.bat
templates/app/hello-android@gradle/gradle/wrapper/gradle-wrapper.jar

# 第三方依赖构建产物（vendor 源码保留，build/ 由全局规则忽略）

# 后端选型参考源码（bgfx/sokol/glfw，仅本地比对参考，暂不入库；
# 若某个转正为 sc 后端依赖，再从此处移除对应条目）
vendor/glfw/
vendor/sokol/
vendor/bgfx/

# ssh 组件自包含静态库（由 templates/.scenv/modules/ssh/build.sh 生成）
# 宿主裸名 libssh2.a + 交叉签名变体 libssh2.<triple>.a 均为本地产物
templates/.scenv/modules/ssh/libssh2.a
templates/.scenv/modules/ssh/libssh2.*.a

# plib 跨平台库模板构建产物
templates/plib/*.a
# 模块库 host 默认档（lib<名>.a）= 本地构建产物，不入库；
# 交叉交付变体 lib<名>.<triple>.a 仍随 git 交付。
templates/.scenv/modules/wsi/libwsi.a
templates/.scenv/modules/ui/libui.a
templates/.scenv/modules/layout/liblayout.a

# .scenv 虚拟环境缓存（交叉编译中间物、模块库缓存等）
templates/.scenv/cache/
